[Unit]
Description=Podman Exporter
After=network-online.target

[Container]
Image=quay.io/navidys/prometheus-podman-exporter:{{ podman_exporter_version }}
ContainerName=podman-exporter
Network=monitoring-net
Environment=CONTAINER_HOST=unix:///run/podman/podman.sock
Exec=--collector.enable-all --collector.enhance-metrics
Volume=/run/user/{{ deploy_user_info.uid }}/podman/podman.sock:/run/podman/podman.sock:ro,z
UserNS=keep-id
SecurityLabelDisable=true
NoNewPrivileges=true

[Service]
Restart=always
RestartSec=5s

[Install]
WantedBy=default.target
