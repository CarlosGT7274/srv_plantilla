global:
  resolve_timeout: 5m
  smtp_from: '{{ alertmanager_smtp_user }}'
  smtp_smarthost: 'smtp.gmail.com:587'
  smtp_auth_username: '{{ alertmanager_smtp_user }}'
  smtp_auth_password: '{{ alertmanager_smtp_pass }}'
  smtp_require_tls: true

route:
  group_by: ['alertname']
  group_wait: 10s
  group_interval: 10s
  repeat_interval: 1h
  receiver: 'email-alerts'

receivers:
- name: 'email-alerts'
  email_configs:
  - to: '{{ alertmanager_email_to }}'
    send_resolved: true
    subject: '{% raw %}{{ .GroupLabels.alertname }} - {{ .Status }}{% endraw %}'
    body: '{% raw %}{{ range .Alerts }}{{ .Annotations.summary }} - {{ .Annotations.description }} ({{ .Labels.severity }}){{ end }}{% endraw %}'
